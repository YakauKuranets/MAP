<?xml version="1.0" encoding="utf-8"?>
<!-- DutyTracker v2 — полностью переработанный дизайн на Material 3 -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackground">

    <!-- ════════════════════════════════════════════════════════════
         ЭКРАН ПРИВЯЗКИ УСТРОЙСТВА
         ════════════════════════════════════════════════════════════ -->
    <ScrollView
        android:id="@+id/screen_pair"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <!-- Лого / иконка -->
            <FrameLayout
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:layout_marginTop="40dp"
                android:background="@drawable/bg_circle_primary">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="🛡"
                    android:textSize="40sp"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="DutyTracker"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnBackground"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Привязка устройства"
                android:textSize="15sp"
                android:textColor="?attr/colorOnSurfaceVariant"/>

            <!-- Карточка с формой -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutline">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Адрес сервера"
                        app:startIconDrawable="@android:drawable/ic_menu_compass"
                        app:boxCornerRadiusTopStart="14dp"
                        app:boxCornerRadiusTopEnd="14dp"
                        app:boxCornerRadiusBottomStart="14dp"
                        app:boxCornerRadiusBottomEnd="14dp"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_base_url"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textUri"
                            android:singleLine="true"
                            android:textSize="15sp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:hint="Код привязки (6 цифр)"
                        app:startIconDrawable="@android:drawable/ic_lock_lock"
                        app:counterEnabled="true"
                        app:counterMaxLength="6"
                        app:boxCornerRadiusTopStart="14dp"
                        app:boxCornerRadiusTopEnd="14dp"
                        app:boxCornerRadiusBottomStart="14dp"
                        app:boxCornerRadiusBottomEnd="14dp"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_pair_code"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:maxLength="6"
                            android:singleLine="true"
                            android:textSize="20sp"
                            android:letterSpacing="0.3"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_pair"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="24dp"
                        android:text="Привязать устройство"
                        android:textSize="16sp"
                        app:cornerRadius="16dp"/>

                    <TextView
                        android:id="@+id/tv_pair_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text=""
                        android:textSize="14sp"
                        android:gravity="center"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/colorSecondaryContainer">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💡"
                        android:textSize="20sp"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="В эмуляторе Android Studio сервер доступен как http://10.0.2.2:5000"
                        android:textSize="13sp"
                        android:textColor="?attr/colorOnSecondaryContainer"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <android:Space
                android:layout_width="match_parent"
                android:layout_height="40dp"/>

        </LinearLayout>
    </ScrollView>

    <!-- ════════════════════════════════════════════════════════════
         ЭКРАН ПРОФИЛЯ
         ════════════════════════════════════════════════════════════ -->
    <ScrollView
        android:id="@+id/screen_profile"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar_profile"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                app:title="Мой профиль"
                app:navigationIcon="@android:drawable/ic_menu_close_clear_cancel"
                android:background="?attr/colorBackground"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="20dp"
                android:text="Заполни один раз — данные увидит диспетчер."
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurfaceVariant"/>

            <!-- Поля профиля в карточке -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutline">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="ФИО"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_full_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Номер наряда / позывной"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_duty_number"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Подразделение"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_unit"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Должность"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_position"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Звание"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_rank"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Телефон"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_phone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="phone"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_save_profile"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="20dp"
                        android:text="Сохранить профиль"
                        app:cornerRadius="14dp"/>

                    <TextView
                        android:id="@+id/tv_profile_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text=""
                        android:textSize="13sp"
                        android:gravity="center"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <android:Space
                android:layout_width="match_parent"
                android:layout_height="32dp"/>

        </LinearLayout>
    </ScrollView>

    <!-- ════════════════════════════════════════════════════════════
         ГЛАВНЫЙ ЭКРАН (HOME)
         ════════════════════════════════════════════════════════════ -->
    <ScrollView
        android:id="@+id/screen_home"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- ── Шапка ─────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_header"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="DutyTracker"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnBackground"/>

                    <!-- Индикатор состояния трекинга -->
                    <TextView
                        android:id="@+id/tv_tracking_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="● ВЫКЛ"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:background="@drawable/bg_badge"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_status_line"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Ожидание…"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:maxLines="2"
                    android:ellipsize="end"/>
            </LinearLayout>

            <!-- ── Кнопка ВКЛ/ВЫКЛ ──────────────────────────────── -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_start_stop"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="НАЧАТЬ ДЕЖУРСТВО"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="18dp"
                    app:iconGravity="textStart"
                    style="@style/Widget.DutyTracker.Button.StartStop"/>
            </FrameLayout>

            <!-- ── Режим трекинга ────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="РЕЖИМ ТРЕКИНГА"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/toggle_mode"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_mode_eco"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🌿 Эко"
                        android:textSize="13sp"
                        style="@style/Widget.Material3.Button.OutlinedButton"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_mode_normal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📍 Норма"
                        android:textSize="13sp"
                        style="@style/Widget.Material3.Button.OutlinedButton"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_mode_precise"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🎯 Точно"
                        android:textSize="13sp"
                        style="@style/Widget.Material3.Button.OutlinedButton"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_mode_auto"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🤖 Авто"
                        android:textSize="13sp"
                        style="@style/Widget.Material3.Button.OutlinedButton"/>

                </com.google.android.material.button.MaterialButtonToggleGroup>
            </LinearLayout>

            <!-- ── Плитки статуса (2 колонки, 3 строки) ─────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="СТАТУС УСТРОЙСТВА"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="8dp"/>

                <!-- Строка 1: GPS + Сеть -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="88dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/tile_gps_bg">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="14dp"
                            android:gravity="center_vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="📡  GPS" android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                            <TextView android:id="@+id/tv_tile_gps"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="6dp" android:text="—"
                                android:textSize="20sp" android:textStyle="bold" android:textColor="?attr/colorOnBackground"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="88dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/tile_net_bg">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="14dp"
                            android:gravity="center_vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="📶  Сеть" android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                            <TextView android:id="@+id/tv_tile_net"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="6dp" android:text="—"
                                android:textSize="20sp" android:textStyle="bold" android:textColor="?attr/colorOnBackground"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- Строка 2: Очередь + Точность -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="88dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/tile_queue_bg">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="14dp"
                            android:gravity="center_vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="📤  Очередь" android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                            <TextView android:id="@+id/tv_tile_queue"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="6dp" android:text="0"
                                android:textSize="20sp" android:textStyle="bold" android:textColor="?attr/colorOnBackground"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="88dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/tile_acc_bg">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="14dp"
                            android:gravity="center_vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🎯  Точность" android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                            <TextView android:id="@+id/tv_tile_acc"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="6dp" android:text="—"
                                android:textSize="20sp" android:textStyle="bold" android:textColor="?attr/colorOnBackground"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- Строка 3: Последняя отправка + Батарея -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="88dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/tile_last_bg">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="14dp"
                            android:gravity="center_vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🕐  Отправка" android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                            <TextView android:id="@+id/tv_tile_last"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="6dp" android:text="—"
                                android:textSize="17sp" android:textStyle="bold" android:textColor="?attr/colorOnBackground"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="88dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/tile_battery_bg">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="14dp"
                            android:gravity="center_vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🔋  Батарея" android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                            <TextView android:id="@+id/tv_tile_battery"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="6dp" android:text="—"
                                android:textSize="20sp" android:textStyle="bold" android:textColor="?attr/colorOnBackground"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </LinearLayout>

            <!-- ── Блок проблем ──────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/section_problems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/md_error_container">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="⚠️"
                                android:textSize="18sp"
                                android:layout_marginEnd="8dp"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Обнаружены проблемы"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="@color/md_on_error_container"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/ll_problems"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_open_guide"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginTop="12dp"
                            android:text="Как исправить →"
                            android:textColor="@color/md_on_error_container"
                            app:strokeColor="@color/md_on_error_container"
                            app:cornerRadius="12dp"
                            style="@style/Widget.Material3.Button.OutlinedButton"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ── SOS блок ──────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp"
                android:orientation="vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_sos"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="🆘  SOS — ЭКСТРЕННЫЙ ВЫЗОВ"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:cornerRadius="16dp"
                    style="@style/Widget.DutyTracker.Button.SOS"/>

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/sos_progress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:visibility="gone"
                    app:trackCornerRadius="4dp"/>

                <TextView
                    android:id="@+id/tv_sos_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text=""
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:gravity="center"/>

            </LinearLayout>

            <!-- ── Кнопки навигации ──────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="НАВИГАЦИЯ"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_map"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="🗺  Карта"
                        app:cornerRadius="14dp"
                        style="@style/Widget.Material3.Button.OutlinedButton"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_edit_profile"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginStart="0dp"
                        android:text="👤  Профиль"
                        app:cornerRadius="14dp"
                        style="@style/Widget.Material3.Button.OutlinedButton"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_diag"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="🔧  Диагностика"
                        app:cornerRadius="14dp"
                        style="@style/Widget.Material3.Button.OutlinedButton"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_journal"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:text="📋  Журнал"
                        app:cornerRadius="14dp"
                        style="@style/Widget.Material3.Button.OutlinedButton"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Сброс привязки — деструктивное действие внизу -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingTop="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_reset_pair"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="Сбросить привязку"
                    android:textColor="?attr/colorError"
                    app:strokeColor="?attr/colorError"
                    app:cornerRadius="12dp"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>

            </LinearLayout>

            <!-- Debug info (hidden by default) -->
            <TextView
                android:id="@+id/tv_home_debug"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="8dp"
                android:text=""
                android:textSize="10sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:fontFamily="monospace"
                android:visibility="gone"/>

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
